# ---------------------------------------------------------------------------
# Daily Command Center — environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# ---------------------------------------------------------------------------

# Shared secret that protects the report ingestion endpoint.
# ChatGPT (or curl) must send: Authorization: Bearer <this value>
# Generate one with:  openssl rand -hex 32
REPORT_INGEST_SECRET=replace_with_random_secret

# Public app name shown in the UI (safe to expose to the client).
NEXT_PUBLIC_APP_NAME=Daily Command Center

# Supabase project URL (safe to expose; it is public by design).
NEXT_PUBLIC_SUPABASE_URL=replace_with_supabase_project_url

# Supabase SERVICE ROLE key — server-only. NEVER expose this to the client.
# It bypasses Row Level Security and must only be read in server code.
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

# ---------------------------------------------------------------------------
# Optional, LOCAL DEVELOPMENT ONLY.
# When set to 1 AND Supabase is not configured AND NODE_ENV !== production,
# reports are kept in process memory so you can try the full UI before wiring
# up Supabase. This is hard-disabled in production and never runs on Vercel.
# ---------------------------------------------------------------------------
# DEV_MEMORY_STORE=1
