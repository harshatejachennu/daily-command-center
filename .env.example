# ---------------------------------------------------------------------------
# Daily Command Center — environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# ---------------------------------------------------------------------------

# Shared secret that protects the report ingestion endpoint.
# ChatGPT (or curl) must send: Authorization: Bearer <this value>
# Generate one with:  openssl rand -hex 32
REPORT_INGEST_SECRET=replace_with_random_secret

# Public app name shown in the UI (safe to expose to the client).
NEXT_PUBLIC_APP_NAME=Daily Command Center

# Supabase project URL (safe to expose; it is public by design).
NEXT_PUBLIC_SUPABASE_URL=replace_with_supabase_project_url

# Supabase SERVICE ROLE key — server-only. NEVER expose this to the client.
# It bypasses Row Level Security and must only be read in server code.
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

# ---------------------------------------------------------------------------
# Gmail bridge (primary automation path) — all server-only.
# A ChatGPT Scheduled Task emails the report; the app reads it from Gmail.
# ---------------------------------------------------------------------------

# Secret protecting POST /api/import-from-gmail (and manual cron triggers).
# Separate from REPORT_INGEST_SECRET. Generate with: openssl rand -hex 32
GMAIL_IMPORT_SECRET=replace_with_random_secret

# Google OAuth credentials for read-only Gmail access (see README for setup).
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_REFRESH_TOKEN=replace_with_google_refresh_token

# Gmail search query used to find the report email (override if needed).
GMAIL_REPORT_QUERY=to:harshateja.chennu00+dailycommand@gmail.com subject:DAILY_COMMAND_CENTER_REPORT newer_than:3d

# Optional Gmail label to prefer when searching.
GMAIL_REPORT_LABEL=Daily Command Center

# Optional: only needed if you enable the Vercel Cron route. Vercel sends this
# automatically as a Bearer token to /api/cron/import-daily-report.
# CRON_SECRET=replace_with_random_secret

# ---------------------------------------------------------------------------
# Phone notifications via ntfy (optional). After a report is imported, a short
# summary is pushed to this ntfy topic. Subscribe to the same topic in the ntfy
# app on your phone. The summary contains personal info, so use a LONG, random,
# hard-to-guess topic name (anyone who knows a public ntfy topic can read it).
# ---------------------------------------------------------------------------
NTFY_TOPIC=replace_with_a_long_random_topic_name
# NTFY_SERVER=https://ntfy.sh
# Used as the notification's tap target (opens your dashboard).
# NEXT_PUBLIC_APP_URL=https://test2-t81g.vercel.app

# ---------------------------------------------------------------------------
# Optional, LOCAL DEVELOPMENT ONLY.
# When set to 1 AND Supabase is not configured AND NODE_ENV !== production,
# reports are kept in process memory so you can try the full UI before wiring
# up Supabase. This is hard-disabled in production and never runs on Vercel.
# ---------------------------------------------------------------------------
# DEV_MEMORY_STORE=1
